{
  "name": "snapo-desktop-electron",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . && npm run lint:css",
    "lint:fix": "eslint . --fix && npm run lint:css:fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "start": "npm run build && electron .",
    "cli": "npm run build && ELECTRON_RUN_AS_NODE=1 electron dist-electron/electron/cli-entry.js",
    "package:mac": "npm run build && node scripts/package-macos.mjs",
    "package:mac:release": "npm run build && node scripts/package-macos.mjs release"
  },
  "dependencies": {
    "@devicefarmer/adbkit": "^3.3.8",
    "@vitejs/plugin-react": "^6.0.1",
    "devtools-protocol": "^0.0.1617982",
    "electron": "^41.2.2",
    "fast-xml-parser": "^5.7.2",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^8.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "stylelint": "^16.26.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.1",
    "wait-on": "^7.2.0"
  }
}
